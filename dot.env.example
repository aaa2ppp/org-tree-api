# ============================================
# Настройки логирования
# ============================================

# Уровень детализации логов
# Допустимые значения: DEBUG, INFO, WARN, ERROR
# По умолчанию: INFO
#LOG_LEVEL=INFO

# Выводить логи в человекочитаемом формате вместо JSON
# Допустимые значения: yes / no (или true / false)
# По умолчанию: no (JSON)
#LOG_PLAINTEXT=no


# ============================================
# Настройки HTTP-сервера
# ============================================

# Адрес и порт, на котором сервер будет принимать запросы
# Формат: host:port, где host может быть пустым (":8080")
# NOTE: Для Docker переопределено в docker-compose.yml
SERVER_ADDR=localhost:8080

# Таймаут чтения запроса (от получения соединения до полного чтения тела)
# Формат: число + единица (s - секунды, m - минуты, ms - миллисекунды)
# По умолчанию: 5s
#SERVER_READ_TIMEOUT=5s

# Таймаут записи ответа (от начала отправки заголовков до завершения ответа)
# По умолчанию: 5s
#SERVER_WRITE_TIMEOUT=5s

# Общий таймаут обработки запроса (от чтения до отправки ответа)
# Должен быть больше или равен READ_TIMEOUT + WRITE_TIMEOUT
# По умолчанию: 5s
#SERVER_REQUEST_TIMEOUT=5s

# Таймаут корректного завершения работы сервера при получении сигнала остановки
# За это время сервер должен завершить все активные запросы
# По умолчанию: 10s
#SERVER_SHUTDOWN_TIMEOUT=10s


# ============================================
# Подключение к базе данных (PostgreSQL)
# ============================================

# Адрес и порт БД в формате host:port
# NOTE: Для Docker переопределено в docker-compose.yml
DB_ADDR=localhost:5432

# Имя базы данных
# По умолчанию: postgres
#DB_NAME=postgres

# Имя пользователя БД
# По умолчанию: postgres
#DB_USER=postgres

# Пароль пользователя БД (ОБЯЗАТЕЛЬНЫЙ)
# !!! Сгенерируйте надёжный пароль, не используйте значения по умолчанию !!!
#DB_PASSWORD='your strong password (REQUIRED)'
